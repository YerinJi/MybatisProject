<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="com.multi.mapper.CourseMapper">
    <resultMap id="CourseMap" type="com.multi.dto.CourseDTO">
        <id property="id" column="id"/>
        <result property="code" column="code"/>
        <result property="professor" column="professor"/>
        <result property="credit" column="credit"/>
        <result property="createdAt" column="create_at"/>
    </resultMap>

    <select id="findByStudentId" parameterType="int" resultType="com.multi.dto.CourseDTO">
        SELECT c.id,c.code, c.title, c.professor, c.credit
        FROM course c
        JOIN enrollment e ON e.course_id = c.id
        WHERE e.student_id = #{id}
        ORDER BY c.id DESC
    </select>

    <!-- 전체 강좌목록 (수강신청) -->
    <select id="findAllCourse" resultType="com.multi.dto.CourseDTO">
        SELECT id, code, title, professor, created_at,credit
        FROM course
    </select>

    <!-- 강좌 상세보기-->
    <select id="findCourse" parameterType="int" resultType="com.multi.dto.CourseDTO">
        SELECT id, code, title, professor, enrolled_at
        FROM course
        WHERE id = #{id}
    </select>

    <!-- 강좌 목록 -> 수강자 목록-->



</mapper>